---
import Layout from "@/layouts/layout.astro";
import { getGroupedRankedPassports } from "@/lib/passport";

const rankedPassports = getGroupedRankedPassports();
---

<Layout title="Ranking Paspor Dunia">
	<div class="space-y-12">
		<h1 class="text-5xl font-black italic mb-12">RANKING PASPOR DUNIA</h1>

		{
			rankedPassports.map((group) => (
				<div class="border-b-4 border-black pb-8">
					<div class="flex items-baseline gap-4 mb-6">
						<span class="text-6xl font-black italic text-[#FF3E3E]">
							#{group.rank}
						</span>
						<span class="text-xl font-bold opacity-70">
							Skor Total: {group.totalScore}
						</span>
					</div>

					<div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-4">
						{group.countries.map((country) => (
							<a
								href={`/passport/${country.code.toLowerCase()}`}
								class="bg-white border-2 border-black p-4 shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] hover:bg-[#FF3E3E] hover:text-white transition-colors block"
							>
								<p class="font-black text-lg">{country.code}</p>
								<p class="text-sm font-semibold truncate">{country.name}</p>
							</a>
						))}
					</div>
				</div>
			))
		}
	</div>
</Layout>
